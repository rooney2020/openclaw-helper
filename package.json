{
  "name": "openclaw-helper",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "dist-electron/electron/electron/main.js",
  "scripts": {
    "dev": "concurrently -k \"npm:dev:renderer\" \"npm:dev:electron:build\" \"npm:dev:electron:run\"",
    "dev:renderer": "vite",
    "dev:electron:build": "vue-tsc --noEmit -p tsconfig.electron.json && tsc -p tsconfig.electron.json --watch --preserveWatchOutput",
    "dev:electron:run": "wait-on tcp:5173 dist-electron/electron/electron/main.js && cross-env VITE_DEV_SERVER_URL=http://127.0.0.1:5173 electron .",
    "build": "vite build && tsc -p tsconfig.electron.json",
    "package:linux": "npm run build && electron-packager . openclaw-helper --platform=linux --arch=x64 --out=release --overwrite --prune=true --ignore=release --ignore=node_modules/electron-packager",
    "package:win": "npm run build && electron-packager . openclaw-helper --platform=win32 --arch=x64 --out=release --overwrite --prune=true --ignore=release --ignore=node_modules/electron-packager",
    "typecheck": "vue-tsc --noEmit && vue-tsc --noEmit -p tsconfig.electron.json"
  },
  "dependencies": {
    "@lydell/node-pty": "^1.2.0-beta.12",
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/xterm": "^6.0.0",
    "iconv-lite": "^0.6.3",
    "jszip": "^3.10.1",
    "marked": "^18.0.4",
    "pinia": "^3.0.0",
    "vue": "^3.5.0",
    "vue-router": "^4.5.0",
    "ws": "^8.21.0",
    "xterm": "^5.3.0"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "@types/ws": "^8.18.1",
    "@vitejs/plugin-vue": "^5.2.0",
    "concurrently": "^9.0.1",
    "cross-env": "^10.0.0",
    "electron": "^35.0.0",
    "electron-packager": "^17.1.0",
    "sass": "^1.86.0",
    "typescript": "~5.8.0",
    "vite": "^6.0.0",
    "vue-tsc": "^2.2.0",
    "wait-on": "^8.0.0"
  }
}
